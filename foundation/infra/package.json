{
  "name": "@codenexus/infra",
  "version": "1.0.0",
  "description": "Infrastructure-as-code patterns: config loading, Docker generation, environment management, and service discovery",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }

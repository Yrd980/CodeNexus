{
  "name": "@codenexus/api",
  "version": "1.0.0",
  "description": "Framework-agnostic API patterns: validation, response formatting, routing, CORS, pagination",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "api",
    "validation",
    "routing",
    "rest",
    "cors",
    "pagination",
    "framework-agnostic"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

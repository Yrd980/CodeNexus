{
  "name": "@codenexus/cache-strategy",
  "version": "1.0.0",
  "description": "Multi-strategy caching patterns (LRU, TTL, write-through) with pluggable storage backends",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",

{
  "name": "@codenexus/file-storage",
  "version": "1.0.0",
  "description": "Storage provider abstraction, upload handling, signed URLs, and file metadata utilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "file-storage",
    "s3",
    "upload",
    "signed-urls",
    "blob-storage",
    "provider-abstraction"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

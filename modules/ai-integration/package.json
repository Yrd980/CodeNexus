  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "streaming",
    "prompt-engineering",
    "cost-tracking"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
